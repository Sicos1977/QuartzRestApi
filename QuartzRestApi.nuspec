<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://microsoft.com">
  <metadata>
    <id>QuartzRestApi</id>
    <version>1.0.3</version>
    <authors>Kees van Spelde</authors>
    <company>Magic-Sessions</company>
    <product>QuartzRestApi</product>
    <description>A self-hosted REST API library for Quartz.NET. Exposes a Quartz IScheduler over HTTP with optional API-key authentication. Supports both modern .NET 10 (Kestrel/Scalar) and classic .NET Framework 4.6.2 (OWIN/WebAPI2).</description>
    <copyright>Copyright (C) 2022 - 2026 Magic-Sessions</copyright>
    <tags>quartz;scheduler;rest;api;kestrel;aspnetcore;owin;webapi;netframework</tags>
    <license type="expression">MIT</license>

    <!-- Project website & Metadata links -->
    <projectUrl>https://github.com</projectUrl>
    <repository type="git" url="https://github.com" />
    <readme>README.md</readme>
    <icon>icon.png</icon>
    
    <dependencies>
      <!-- Dependencies voor .NET Framework 4.6.2 -->
      <group targetFramework=".NETFramework4.6.2">
        <dependency id="Quartz" version="3.18.1" />
        <dependency id="Microsoft.Owin.SelfHost" version="4.2.3" />
        <dependency id="Microsoft.AspNet.WebApi.OwinSelfHost" version="5.3.0" />
        <dependency id="Newtonsoft.Json" version="13.0.4" />
      </group>
      <!-- Dependencies voor .NET 10.0 -->
      <group targetFramework="net10.0">
        <dependency id="Quartz" version="3.18.1" />
        <dependency id="Microsoft.AspNetCore.OpenApi" version="10.0.8" />
        <dependency id="Microsoft.Extensions.Hosting" version="10.0.8" />
        <dependency id="Scalar.AspNetCore" version="2.14.14" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- Root metadata files -->
    <file src="README.md" target="README.md" />
    <file src="LICENSE" target="LICENSE" />
    <file src="icon.png" target="icon.png" />

    <!-- .NET Framework 4.6.2 binaries -->
    <file src="QuartzRestApi.Net462/bin/Release/net462/QuartzRestApi.dll" target="lib/net462/QuartzRestApi.dll" />
    <file src="QuartzRestApi.Net462/bin/Release/net462/QuartzRestApi.xml" target="lib/net462/QuartzRestApi.xml" />

    <!-- .NET 10.0 binaries -->
    <file src="QuartzRestApi/bin/Release/net10.0/QuartzRestApi.dll" target="lib/net10.0/QuartzRestApi.dll" />
    <file src="QuartzRestApi/bin/Release/net10.0/QuartzRestApi.xml" target="lib/net10.0/QuartzRestApi.xml" />
  </files>
</package>
